---
import Layout from '../layouts/Layout.astro';
import { WHATSAPP } from '../lib/config';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Historia from '../components/Historia.astro';
import Productos from '../components/Productos.astro';
import Combos from '../components/Combos.astro';
import Galeria from '../components/Galeria.astro';
import ComoPedir from '../components/ComoPedir.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div id="payment-status" class="hidden" data-wa-number={WHATSAPP.number}></div>
  <Nav />
  <Hero />
  <Historia />
  <Productos />
  <Combos />
  <Galeria />
  <ComoPedir />
  <Footer />
</Layout>

<script>
  const waNumber = (document.getElementById('payment-status') as HTMLElement).dataset.waNumber!;
  const params = new URLSearchParams(window.location.search);
  const status = params.get('status');
  const paymentId = params.get('payment_id');
  const preferenceId = params.get('preference_id');

  if (!status) {
    sessionStorage.removeItem('guayafood_order');
  }

  function getOrderData() {
    const raw = sessionStorage.getItem('guayafood_order');
    if (raw) {
      try { return JSON.parse(raw); } catch { /* fall through */ }
    }
    return null;
  }

  function clearOrderData() {
    sessionStorage.removeItem('guayafood_order');
  }

  let saveSuccess = false;
  let savedData = null;

  async function saveOrder(data) {
    try {
      const res = await fetch('/api/save-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          preferenceId: preferenceId || data.preferenceId || 'link_directo',
          paymentId: paymentId || '',
          status: 'approved',
          name: data.name,
          phone: data.phone,
          address: data.address,
          barrio: data.barrio || '',
          reference: data.reference || '',
          items: data.items,
          total: data.total,
          notes: data.notes || '',
          deliveryDate: data.deliveryDate || '',
          deliveryTime: data.deliveryTime || '',
        }),
      });
      return res.ok;
    } catch (err) {
      console.error('Error saving order:', err);
      return false;
    }
  }

  async function trySave(data) {
    savedData = data;
    saveSuccess = await saveOrder(data);
    if (saveSuccess) {
      clearOrderData();
    }
  }

  function buildWaText(data) {
    const items = (data.items || []).map((i) => `${i.title} x${i.quantity}`).join(', ');
    let text = `Hola! Ya hice el pago por Mercado Pago 🎉\n\n`;
    text += `📦 Productos: ${items}\n`;
    text += `💰 Total: $${(data.total || 0).toLocaleString('es-AR')}\n`;
    text += `👤 Nombre: ${data.name}\n`;
    text += `📞 Teléfono: ${data.phone}\n`;
    text += `📍 Dirección: ${data.address}\n`;
    if (data.barrio) text += `🏘️ Barrio: ${data.barrio}\n`;
    if (data.reference) text += `🏠 Referencia: ${data.reference}\n`;
    if (data.deliveryDate) text += `📅 Fecha: ${data.deliveryDate}\n`;
    if (data.deliveryTime) text += `⏰ Horario: ${data.deliveryTime}\n`;
    if (data.notes) text += `📝 Notas: ${data.notes}\n`;
    if (paymentId) text += `\n🧾 ID de pago: ${paymentId}`;
    return text;
  }

  function showBanner(type, data, opts = {}) {
    const div = document.getElementById('payment-status');
    div.classList.remove('hidden');

    if (type === 'approved') {
      const waText = data ? buildWaText(data) : 'Hola! Ya hice el pago por Mercado Pago';
      const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(waText)}`;
      const retryBtn = opts.saveFailed
        ? `<button onclick="retrySave()" class="block mx-auto mt-2 text-xs bg-green-700 text-white px-4 py-2 rounded-full hover:bg-green-800 transition-colors">🔄 Reintentar guardar pedido</button>`
        : '';

      div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-green-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
      div.innerHTML = `
        <span class="text-3xl block mb-2">✅</span>
        <h3 class="font-bold text-lg mb-1">¡Pago recibido!</h3>
        <p class="text-green-100 text-sm mb-1">Gracias por tu compra.</p>
        <p class="text-green-200 text-xs mb-3">${opts.saveFailed ? 'El pedido no se guardó automáticamente.' : 'Redirigiendo a WhatsApp para coordinar la entrega...'}</p>
        <a href="${waUrl}" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-green-700 font-bold px-6 py-3 rounded-full text-sm mb-2 hover:bg-green-50 transition-colors">
          📲 Abrir WhatsApp ahora
        </a>
        ${retryBtn}
        <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-green-200 underline">Cerrar</button>
      `;

      if (!opts.saveFailed) {
        setTimeout(() => { window.location.href = waUrl; }, 2500);
      }
    } else if (type === 'failure') {
      div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-red-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
      div.innerHTML = `
        <span class="text-3xl block mb-2">❌</span>
        <h3 class="font-bold text-lg mb-1">Pago no completado</h3>
        <p class="text-red-100 text-sm mb-3">El pago no pudo procesarse. Podés intentar de nuevo o pedir por WhatsApp.</p>
        <a href="https://wa.me/${waNumber}" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-red-700 font-bold px-6 py-3 rounded-full text-sm hover:bg-red-50 transition-colors">
          📲 Pedir por WhatsApp
        </a>
        <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-red-200 underline">Cerrar</button>
      `;
    } else if (type === 'pending') {
      div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-yellow-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
      div.innerHTML = `
        <span class="text-3xl block mb-2">⏳</span>
        <h3 class="font-bold text-lg mb-1">Pago pendiente</h3>
        <p class="text-yellow-100 text-sm mb-3">Estamos esperando la confirmación del pago. Si ya pagaste, envianos el comprobante por WhatsApp.</p>
        <a href="https://wa.me/${waNumber}" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-yellow-700 font-bold px-6 py-3 rounded-full text-sm hover:bg-yellow-50 transition-colors">
          📲 Enviar comprobante
        </a>
        <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-yellow-200 underline">Cerrar</button>
      `;
    }
  }

  if (status === 'approved') {
    (async () => {
      let verified = !paymentId;
      let apiOrderData = null;
      if (paymentId) {
        try {
          const res = await fetch('/api/verify-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ payment_id: paymentId, preference_id: preferenceId }),
          });
          const data = await res.json();
          verified = data.verified === true;
          apiOrderData = data.orderData || null;
        } catch {
          verified = false;
        }
      }
      if (verified) {
        const data = apiOrderData || getOrderData();
        if (data) {
          await trySave(data);
        }
        showBanner('approved', data, { saveFailed: data && !saveSuccess });
      } else {
        showBanner('failure');
      }
    })();
    window.history.replaceState({}, '', '/');
  } else if (status === 'failure') {
    clearOrderData();
    showBanner('failure');
    window.history.replaceState({}, '', '/');
  } else if (status === 'pending') {
    showBanner('pending');
    window.history.replaceState({}, '', '/');
  }

  window.retrySave = async function () {
    if (!savedData) return;
    saveSuccess = await saveOrder(savedData);
    if (saveSuccess) {
      clearOrderData();
      const div = document.getElementById('payment-status');
      div.innerHTML = '<p class="text-green-100 text-sm">✅ Pedido guardado correctamente.</p>';
      setTimeout(() => div.classList.add('hidden'), 3000);
    }
  };

</script>
