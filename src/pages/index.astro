---
import Layout from '../layouts/Layout.astro';
import { WHATSAPP } from '../lib/config';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Historia from '../components/Historia.astro';
import Productos from '../components/Productos.astro';
import Combos from '../components/Combos.astro';
import Galeria from '../components/Galeria.astro';
import ComoPedir from '../components/ComoPedir.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div id="payment-status" class="hidden"></div>
  <Nav />
  <Hero />
  <Historia />
  <Productos />
  <Combos />
  <Galeria />
  <ComoPedir />
  <Footer />
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const status = params.get('status');

  function getOrderData() {
    const raw = localStorage.getItem('guayafood_order') || sessionStorage.getItem('guayafood_order');
    if (!raw) return null;
    try { return JSON.parse(raw); } catch { return null; }
  }

  function clearOrderData() {
    localStorage.removeItem('guayafood_order');
    sessionStorage.removeItem('guayafood_order');
  }

  async function saveOrder(data) {
    try {
      await fetch('/api/save-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          preferenceId: data.preferenceId || 'link_directo',
          status: 'approved',
          name: data.name,
          phone: data.phone,
          address: data.address,
          reference: data.reference || '',
          items: data.items,
          total: data.total,
          notes: data.notes || '',
          deliveryDate: data.deliveryDate || '',
          deliveryTime: data.deliveryTime || '',
        }),
      });
    } catch (err) {
      console.error('Error saving order:', err);
    }
  }

  function buildWaText(data) {
    const items = (data.items || []).map((i) => `${i.title} x${i.quantity}`).join(', ');
    let text = `Hola! Ya hice el pago por Mercado Pago 🎉\n\n`;
    text += `📦 Productos: ${items}\n`;
    text += `💰 Total: $${(data.total || 0).toLocaleString('es-AR')}\n`;
    text += `👤 Nombre: ${data.name}\n`;
    text += `📞 Teléfono: ${data.phone}\n`;
    text += `📍 Dirección: ${data.address}\n`;
    if (data.reference) text += `🏠 Referencia: ${data.reference}\n`;
    if (data.deliveryDate) text += `📅 Fecha: ${data.deliveryDate}\n`;
    if (data.deliveryTime) text += `⏰ Horario: ${data.deliveryTime}\n`;
    if (data.notes) text += `📝 Notas: ${data.notes}\n`;
    return text;
  }

  if (status === 'approved') {
    const data = getOrderData();
    if (data) {
      saveOrder(data);
      clearOrderData();
    }

    const waText = data ? buildWaText(data) : 'Hola! Ya hice el pago por Mercado Pago';
    const waUrl = `https://wa.me/5491123861180?text=${encodeURIComponent(waText)}`;

    const div = document.getElementById('payment-status');
    div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-green-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
    div.innerHTML = `
      <span class="text-3xl block mb-2">✅</span>
      <h3 class="font-bold text-lg mb-1">¡Pago recibido!</h3>
      <p class="text-green-100 text-sm mb-3">Gracias por tu compra. Ahora envianos el comprobante por WhatsApp para confirmar tu pedido.</p>
      <a href="${waUrl}" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-green-700 font-bold px-6 py-3 rounded-full text-sm mb-2 hover:bg-green-50 transition-colors">
        📲 Enviar comprobante por WhatsApp
      </a>
      <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-green-200 underline">Cerrar</button>
    `;
    div.classList.remove('hidden');

    window.history.replaceState({}, '', '/');
  } else if (status === 'failure') {
    clearOrderData();

    const div = document.getElementById('payment-status');
    div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-red-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
    div.innerHTML = `
      <span class="text-3xl block mb-2">❌</span>
      <h3 class="font-bold text-lg mb-1">Pago no completado</h3>
      <p class="text-red-100 text-sm mb-3">El pago no pudo procesarse. Podés intentar de nuevo o pedir por WhatsApp.</p>
      <a href="https://wa.me/5491123861180" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-red-700 font-bold px-6 py-3 rounded-full text-sm hover:bg-red-50 transition-colors">
        📲 Pedir por WhatsApp
      </a>
      <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-red-200 underline">Cerrar</button>
    `;
    div.classList.remove('hidden');

    window.history.replaceState({}, '', '/');
  } else if (status === 'pending') {
    const div = document.getElementById('payment-status');
    div.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-[60] bg-yellow-600 text-white px-6 py-4 rounded-2xl shadow-2xl max-w-md w-full mx-4 text-center';
    div.innerHTML = `
      <span class="text-3xl block mb-2">⏳</span>
      <h3 class="font-bold text-lg mb-1">Pago pendiente</h3>
      <p class="text-yellow-100 text-sm mb-3">Estamos esperando la confirmación del pago. Si ya pagaste, envianos el comprobante por WhatsApp.</p>
      <a href="https://wa.me/5491123861180" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-yellow-700 font-bold px-6 py-3 rounded-full text-sm hover:bg-yellow-50 transition-colors">
        📲 Enviar comprobante
      </a>
      <button onclick="this.parentElement.remove()" class="block mx-auto mt-2 text-xs text-yellow-200 underline">Cerrar</button>
    `;
    div.classList.remove('hidden');

    window.history.replaceState({}, '', '/');
  }
</script>
