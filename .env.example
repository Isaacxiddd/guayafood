# Mercado Pago - Access Token (prod)
# Obtenelo desde https://www.mercadopago.com.ar/settings/account/credentials
MERCADOPAGO_ACCESS_TOKEN=

# Link directo de pago de MP (fallback si no hay access token)
PUBLIC_MP_LINK=https://link.mercadopago.com.ar/guayafood

# URL pública del sitio (usada para redirects post-pago)
PUBLIC_SITE_URL=https://guayafood.vercel.app

# (Opcional) URL de la API de preferencias (por defecto /api/create-preference)
# PUBLIC_MP_API_URL=/api/create-preference

# (Opcional) Horas mínimas de anticipación para pedidos (default: 24)
# PUBLIC_ADVANCE_HOURS=24

# (Opcional) Máximo de pedidos por franja horaria (default: 3)
# PUBLIC_MAX_ORDERS_PER_SLOT=3

# ─── Google Sheets ───────────────────────────────────────────────
# 1. Creá un proyecto en https://console.cloud.google.com
# 2. Habilitá Google Sheets API
# 3. Creá una service account y descargá el JSON
# 4. Codificá el JSON a base64:
#    PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("ruta\creds.json"))
#    Linux/Mac:   base64 -i creds.json
# 5. Compartí tu planilla con el email de la service account
# 6. Copiá el ID de la planilla desde la URL (el hash entre /d/ y /edit)
GOOGLE_CREDENTIALS_BASE64=
GOOGLE_SHEET_ID=
